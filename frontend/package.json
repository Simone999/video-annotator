{
  "name": "video-annotator-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src tests --max-warnings=0",
    "lint:fix": "eslint src tests --fix --max-warnings=0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node scripts/run-vitest-coverage.mjs && node scripts/check-vitest-coverage-gate.mjs coverage/coverage-summary.json 90",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:sharded": "VITEST_COVERAGE_SHARDED=1 node scripts/run-vitest-coverage.mjs && node scripts/check-vitest-coverage-gate.mjs coverage/coverage-summary.json 90",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@storybook/react-vite": "^9.0.15",
    "@tailwindcss/vite": "^4.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "jsdom": "^29.0.2",
    "msw": "^2.11.6",
    "playwright": "^1.59.1",
    "prettier": "^3.5.3",
    "storybook": "^9.0.15",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^7.1.2",
    "vitest": "^4.1.4"
  }
}
